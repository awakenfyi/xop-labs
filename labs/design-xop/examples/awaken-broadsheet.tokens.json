{
  "$description": "awaken Broadsheet — a Design xOP produced by merging Titan (styles.refero.design) × factory.ai. Tokens observed from site/awaken/assets/site.css. Rules: DESIGNED.",
  "color": {
    "ink":      { "$value": "#1b1c1c", "$type": "color", "$description": "Primary text + structural hairlines — soft warm near-black, never pure #000" },
    "graphite": { "$value": "#615e5b", "$type": "color", "$description": "Secondary text" },
    "ash":      { "$value": "#8a8784", "$type": "color", "$description": "Tertiary text / fine print" },
    "paper":    { "$value": "#fbf9f6", "$type": "color", "$description": "Warm cream canvas" },
    "paper-2":  { "$value": "#f4f1ec", "$type": "color", "$description": "Section wash" },
    "linen":    { "$value": "#eeeae3", "$type": "color", "$description": "Card surface" },
    "sand":     { "$value": "#e3ddd3", "$type": "color", "$description": "Accent surface / divider" },
    "line":     { "$value": "#dcd7ce", "$type": "color", "$description": "Hairline border" },
    "accent":   { "$value": "#8B7EC8", "$type": "color", "$description": "The single accent — lavender, used as punctuation" }
  },
  "font": {
    "sans": { "$value": "Geist", "$type": "fontFamily", "$description": "All UI + display. Substitute: Inter, system-ui." },
    "mono": { "$value": "Geist Mono", "$type": "fontFamily", "$description": "Numbers, IDs, evidence statuses, plate markers, code only." }
  },
  "typography": {
    "label":   { "$value": { "fontFamily": "Geist Mono", "fontSize": "12px", "fontWeight": 500, "lineHeight": 1.3, "letterSpacing": "0.06em", "textTransform": "uppercase" }, "$type": "typography", "$description": "Mono utility label / plate" },
    "body":    { "$value": { "fontFamily": "Geist", "fontSize": "16px", "fontWeight": 400, "lineHeight": 1.55 }, "$type": "typography", "$description": "Body copy" },
    "body-lg": { "$value": { "fontFamily": "Geist", "fontSize": "18px", "fontWeight": 400, "lineHeight": 1.55 }, "$type": "typography", "$description": "Lead / hero copy" },
    "stat":    { "$value": { "fontFamily": "Geist Mono", "fontSize": "28px", "fontWeight": 500, "lineHeight": 1.0 }, "$type": "typography", "$description": "Numeric figure" },
    "heading": { "$value": { "fontFamily": "Geist", "fontSize": "40px", "fontWeight": 600, "lineHeight": 1.1, "letterSpacing": "-0.03em" }, "$type": "typography", "$description": "Section heading" },
    "display": { "$value": { "fontFamily": "Geist", "fontSize": "60px", "fontWeight": 700, "lineHeight": 1.0, "letterSpacing": "-0.045em" }, "$type": "typography", "$description": "Hero display" }
  },
  "spacing": {
    "unit":    { "$value": "4px",  "$type": "dimension" },
    "card":    { "$value": "24px", "$type": "dimension", "$description": "Card padding" },
    "element": { "$value": "16px", "$type": "dimension", "$description": "Element gap" },
    "section": { "$value": "80px", "$type": "dimension", "$description": "Section gap" },
    "max-width": { "$value": "1200px", "$type": "dimension", "$description": "Page max width" }
  },
  "radius": {
    "pill":   { "$value": "999px", "$type": "dimension", "$description": "Buttons, nav, chips, tags, status" },
    "card":   { "$value": "24px",  "$type": "dimension", "$description": "Cards, panels, specimens" },
    "panel":  { "$value": "18px",  "$type": "dimension", "$description": "Small inset panels" },
    "input":  { "$value": "12px",  "$type": "dimension", "$description": "Inputs / textareas" }
  },
  "surface": {
    "0-paper":  { "$value": "#fbf9f6", "$type": "color", "$description": "Canvas" },
    "1-wash":   { "$value": "#f4f1ec", "$type": "color", "$description": "Section wash" },
    "2-linen":  { "$value": "#eeeae3", "$type": "color", "$description": "Card surface" },
    "3-ink":    { "$value": "#1b1c1c", "$type": "color", "$description": "Dark statement / footer" }
  },
  "$extensions": {
    "elevation": "Zero shadow. Depth via 1px hairlines and surface shifts only.",
    "merge": { "base": "Titan", "borrowed": "factory.ai (soft canvas + non-black ink)", "kept": "single lavender accent", "status": "DESIGNED" }
  }
}
